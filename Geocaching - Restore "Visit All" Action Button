// ==UserScript==
// @name         Geocaching - Restore "Visit All" Action Button
// @namespace    http://tampermonkey.net
// @version      3.4.0
// @description  Restores the missing "Visit all" link to the inventory header and footer. Displays and functions perfectly only after "Show all" has been clicked.
// @author       You
// @match        https://geocaching.com*
// @license      GNU GPLv3
// @grant        none
// @run-at       document-start
// ==/UserScript==

(function() {
    'use strict';

    const targetActionText = 'visit';
    const scrollAmount = 550; 
    const tickInterval = 300; 

    // Helper: Safely triggers hardware level events past NextJS hydration blocks
    function triggerFrameworkSafeClick(element) {
        if (!element) return;
        try {
            if (!element.id) {
                element.id = "gclh_auto_generated_" + Math.random().toString(36).substr(2, 9);
            }
            ['pointerdown', 'mousedown', 'pointerup', 'mouseup', 'click'].forEach(type => {
                const ev = new PointerEvent(type, {
                    view: window, bubbles: true, cancelable: true, isTrusted: true, buttons: 1, relatedTarget: element
                });
                element.dispatchEvent(ev);
            });
        } catch (e) {
            console.log("[Auto-Clicker Warning] Suppressed event click error.");
        }
    }

    // CORE ENGINE: Automatically runs the sweeping pass through the expanded list
    function runInfiniteScrollAndClick(statusLink) {
        let totalProcessed = 0;
        let lastScrollHeight = 0;
        let structuralStagnantCycles = 0;

        // Update all instances of the "Visit All" link text to "Processing..."
        const allStatusLinks = document.querySelectorAll('.gclh-custom-visit-all-link');
        allStatusLinks.forEach(link => {
            link.textContent = "Processing...";
            link.style.color = "#e67e22"; // Warm warning orange during operation
        });
        
        console.log("[Auto-Clicker] User triggered sequence. Beginning infinite-scroll processing pass...");

        const container = document.querySelector('ul.tb-list.gclh_TBsObserver') || 
                          document.querySelector('ul.tb-list') || 
                          document.documentElement;

        const engineTimer = setInterval(() => {
            try {
                const currentButtons = document.querySelectorAll('button');
                let clickedInThisFrame = 0;

                // 1. Scan and toggle viewport nodes
                currentButtons.forEach(button => {
                    try {
                        const label = button.textContent.trim().toLowerCase();
                        if (label === targetActionText && button.getAttribute('aria-checked') !== 'true') {
                            triggerFrameworkSafeClick(button);
                            clickedInThisFrame++;
                            totalProcessed++;
                            
                            // Dynamically update the count on both links simultaneously
                            allStatusLinks.forEach(link => {
                                link.textContent = `Visiting... (${totalProcessed})`;
                            });
                        }
                    } catch (rowErr) {}
                });

                // 2. Adjust dynamic container scrolling boundaries
                let currentScrollHeight = 0;
                if (container && container !== document.documentElement) {
                    container.scrollTop += scrollAmount;
                    currentScrollHeight = container.scrollHeight;
                } else {
                    window.scrollBy(0, scrollAmount);
                    currentScrollHeight = document.documentElement.scrollHeight;
                }

                // 3. Termination evaluation
                if (clickedInThisFrame === 0 && currentScrollHeight === lastScrollHeight) {
                    structuralStagnantCycles++;
                    if (structuralStagnantCycles >= 10) { 
                        clearInterval(engineTimer);
                        
                        // Set both links to success state green
                        allStatusLinks.forEach(link => {
                            link.textContent = `Visit All ✔ (${totalProcessed})`;
                            link.style.color = "#27ae60"; 
                        });
                        console.log(`[Auto-Clicker] 🏁 Sweep absolute. Processed: ${totalProcessed}`);
                    }
                } else {
                    structuralStagnantCycles = 0;
                }

                lastScrollHeight = currentScrollHeight;

            } catch (err) {
                console.log("[Auto-Clicker Error] Main thread catch protected runtime loop.");
            }
        }, tickInterval);
    }

    // UI RESTORATION LAYER: Safely builds an isolated link copy with complete click functionality
    function injectVisitAllButton(containerElement) {
        // Build matching styled button component matching Geocaching stylesheet designs
        const visitAllBtn = document.createElement('button');
        // Use a generic class so we can change texts together, but a unique ID per injection step
        visitAllBtn.className = "gclh-custom-visit-all-link inline-block m-0 p-0 border-0 text-base bg-transparent font-input underline cursor-pointer text-blue-500 hover:no-underline";
        visitAllBtn.type = 'button';
        visitAllBtn.textContent = 'Visit All';
        visitAllBtn.style.marginLeft = "12px"; 

        // Bind click execution to the master engine handler
        visitAllBtn.addEventListener('click', (e) => {
            e.preventDefault();
            runInfiniteScrollAndClick(visitAllBtn);
        });

        containerElement.appendChild(visitAllBtn);
    }

    // WATCHDOG INTERCEPT: Dynamically watches for the user to click "Show All" on any button row
    function attachShowAllListener() {
        // Query all instances of the "Show All" button (both top and bottom sections)
        const showAllButtons = document.querySelectorAll('button[data-event-label="Cache Log - show all"], button.gclh_hideTB_event');
        
        showAllButtons.forEach(showAllBtn => {
            if (showAllBtn.dataset.clickMonitorAttached === "true") return;

            // Find the immediate parent button row layer container for this specific button
            const targetContainer = showAllBtn.closest('div.button-container') || showAllBtn.parentElement;
            if (!targetContainer) return;

            showAllBtn.dataset.clickMonitorAttached = "true";
            console.log("[Auto-Clicker] Production hook linked to a 'Show all' button container element.");

            // Monitor when this specific row is triggered by the user
            showAllBtn.addEventListener('click', () => {
                // Give the DOM a tiny 150ms window to clear rendering frames, then inject into the specific container
                setTimeout(() => {
                    // Check to make sure we haven't already added a button to this specific container row layout
                    if (!targetContainer.querySelector('.gclh-custom-visit-all-link')) {
                        injectVisitAllButton(targetContainer);
                    }
                }, 150);
            });
        });
    }

    // Continuous background watch ensures footer clone buttons receive links if they inject late
    const uiObserver = new MutationObserver(() => attachShowAllListener());
    uiObserver.observe(document.documentElement, { childList: true, subtree: true });

    if (document.readyState === 'complete' || document.readyState === 'interactive') {
        attachShowAllListener();
    }
})();
