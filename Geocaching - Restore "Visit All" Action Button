// ==UserScript==
// @name geocaching - restore "visit all" action button
// @namespace http://tampermonkey.net
// @version 9.0.0
// @description restores the missing inline "visit all" text link right beside the inventory master controls after expansion.
// @author breezewood
// @match https://geocaching.com*
// @license gnu gplv3
// @grant none
// @run-at document-start
// ==/UserScript==

(function() {
    'use strict';
    
    const targetactiontext = 'visit';
    const scrollamount = 550;
    const tickinterval = 300;
    let enginetimer = null;

    // helper: safely triggers hardware level events past nextjs hydration blocks
    function triggerframeworksafeclick(element) {
        if (!element) return;
        try {
            if (!element.id) {
                element.id = "gclh_auto_generated_" + Math.random().toString(36).substr(2, 9);
            }
            ['pointerdown', 'mousedown', 'pointerup', 'mouseup', 'click'].forEach(type => {
                const ev = new PointerEvent(type, {
                    view: window,
                    bubbles: true,
                    cancelable: true,
                    isTrusted: true,
                    buttons: 1,
                    relatedTarget: element
                });
                element.dispatchEvent(ev);
            });
        } catch (e) {
            console.log("[auto-clicker warning] suppressed event click error.");
        }
    }

    // core engine: automatically runs the sweeping pass through the expanded list
    function runinfinitescrollandclick() {
        if (enginetimer) clearInterval(enginetimer);

        let totalProcessed = 0;
        let lastScrollHeight = 0;
        let structuralStagnantCycles = 0;

        const allStatusLinks = document.querySelectorAll('.gclh-custom-visit-all-link');
        allStatusLinks.forEach(link => {
            link.textContent = "processing...";
            link.style.color = "#e67e22"; // warning orange
            link.dataset.executionstate = "running";
        });

        console.log("[auto-clicker] sequence triggered. beginning inventory pass.");

        enginetimer = setInterval(() => {
            // Find all toggle buttons or dropdowns for trackables in the inventory
            const inventoryContainers = document.querySelectorAll('.trackable-item-container'); 
            
            // If containers exist, process actions
            if (inventoryContainers.length > 0) {
                inventoryContainers.forEach(container => {
                    const dropdownToggle = container.querySelector('.action-dropdown-toggle'); // Adjust class based on Geocaching.com exact DOM
                    const actionOptions = container.querySelectorAll('.dropdown-menu-item'); // Adjust class for action lists
                    
                    if (dropdownToggle && !container.dataset.hasVisited) {
                        triggerframeworksafeclick(dropdownToggle);
                        
                        // Select "Visit" from the dropdown options
                        setTimeout(() => {
                            actionOptions.forEach(opt => {
                                if (opt.textContent.toLowerCase().includes(targetactiontext)) {
                                    triggerframeworksafeclick(opt);
                                    totalProcessed++;
                                    container.dataset.hasVisited = "true";
                                }
                            });
                        }, 50); // Small delay to allow dropdown render
                    }
                });
            }

            // Infinite Scroll Mechanics to trigger lazy loading
            const currentScrollHeight = document.documentElement.scrollHeight;
            window.scrollBy(0, scrollamount);

            if (currentScrollHeight === lastScrollHeight) {
                structuralStagnantCycles++;
            } else {
                structuralStagnantCycles = 0;
                lastScrollHeight = currentScrollHeight;
            }

            // Stop scrolling if we reach the bottom of the lazy-loaded container
            if (structuralStagnantCycles > 5) {
                clearInterval(enginetimer);
                console.log(`[auto-clicker] completed. total trackables visited: ${totalProcessed}`);
                
                // Reset UI indicators
                allStatusLinks.forEach(link => {
                    link.textContent = "visited all";
                    link.style.color = "#27ae60"; // success green
                    link.dataset.executionstate = "completed";
                });
            }
        }, tickinterval);
    }

    // Initialize observer to detect when the log page fully loads the trackable inventory
    const observer = new MutationObserver((mutations) => {
        mutations.forEach(mutation => {
            if (mutation.addedNodes.length > 0) {
                // Check if the added node corresponds to the trackable container
                const isTrackableList = Array.from(mutation.addedNodes).some(node => 
                    node.classList && node.classList.contains('trackables-section')
                );
                
                if (isTrackableList && !document.querySelector('.gclh-custom-visit-all-link')) {
                    // Re-inject your custom button here
                    const controls = document.querySelector('.inventory-master-controls'); // Adjust selector as needed
                    if (controls && !document.getElementById('custom-visit-all-btn')) {
                        const btn = document.createElement('span');
                        btn.id = 'custom-visit-all-btn';
                        btn.className = 'gclh-custom-visit-all-link';
                        btn.textContent = 'visit all';
                        btn.style.cursor = 'pointer';
                        btn.style.color = '#3498db';
                        btn.style.marginLeft = '10px';
                        btn.addEventListener('click', runinfinitescrollandclick);
                        controls.appendChild(btn);
                    }
                }
            }
        });
    });

    observer.observe(document.body, { childList: true, subtree: true });
})();
