// ==UserScript==
// @name         Geocaching - Restore "Visit All" Action Button
// @namespace    http://tampermonkey.net
// @version      9.0.0
// @description  Restores the missing inline "Visit All" text link right beside the inventory master controls after expansion.
// @author       Breezewood
// @match        https://geocaching.com*
// @license      GNU GPLv3
// @grant        none
// @run-at       document-start
// ==/UserScript==

(function() {
    'use strict';

    const targetActionText = 'visit';
    const scrollAmount = 550; 
    const tickInterval = 300; 

    let engineTimer = null;

    // Helper: Safely triggers hardware level events past NextJS hydration blocks
    function triggerFrameworkSafeClick(element) {
        if (!element) return;
        try {
            if (!element.id) {
                element.id = "gclh_auto_generated_" + Math.random().toString(36).substr(2, 9);
            }
            ['pointerdown', 'mousedown', 'pointerup', 'mouseup', 'click'].forEach(type => {
                const ev = new PointerEvent(type, {
                    view: window, bubbles: true, cancelable: true, isTrusted: true, buttons: 1, relatedTarget: element
                });
                element.dispatchEvent(ev);
            });
        } catch (e) {
            console.log("[Auto-Clicker Warning] Suppressed event click error.");
        }
    }

    // CORE ENGINE: Automatically runs the sweeping pass through the expanded list
    function runInfiniteScrollAndClick() {
        if (engineTimer) clearInterval(engineTimer);

        let totalProcessed = 0;
        let lastScrollHeight = 0;
        let structuralStagnantCycles = 0;

        const allStatusLinks = document.querySelectorAll('.gclh-custom-visit-all-link');
        allStatusLinks.forEach(link => {
            link.textContent = "Processing...";
            link.style.color = "#e67e22"; // Warning orange
            link.dataset.executionState = "running";
        });
        
        console.log("[Auto-Clicker] Sequence triggered. Beginning infinite-scroll processing pass...");

        const container = document.querySelector('ul.tb-list') || document.documentElement;

        engineTimer = setInterval(() => {
            try {
                const currentButtons = document.querySelectorAll('button');
                let clickedInThisFrame = 0;

                // 1. Scan and toggle viewport nodes
                currentButtons.forEach(button => {
                    try {
                        const label = button.textContent.trim().toLowerCase();
                        // Target individual item row selection options explicitly, skipping macro links
                        if (label === targetActionText && button.getAttribute('aria-checked') !== 'true' && !button.classList.contains('gclh-custom-visit-all-link')) {
                            triggerFrameworkSafeClick(button);
                            clickedInThisFrame++;
                            totalProcessed++;
                            
                            allStatusLinks.forEach(link => {
                                link.textContent = `Visiting... (${totalProcessed})`;
                            });
                        }
                    } catch (rowErr) {}
                });

                // 2. Adjust dynamic container scrolling boundaries
                let currentScrollHeight = 0;
                if (container && container !== document.documentElement) {
                    container.scrollTop += scrollAmount;
                    currentScrollHeight = container.scrollHeight;
                } else {
                    window.scrollBy(0, scrollAmount);
                    currentScrollHeight = document.documentElement.scrollHeight;
                }

                // 3. Termination evaluation
                if (clickedInThisFrame === 0 && currentScrollHeight === lastScrollHeight) {
                    structuralStagnantCycles++;
                    if (structuralStagnantCycles >= 10) { 
                        clearInterval(engineTimer);
                        engineTimer = null;
                        
                        allStatusLinks.forEach(link => {
                            link.textContent = `Visit All ✔ (${totalProcessed})`;
                            link.style.color = "#27ae60"; // Success Green
                            link.dataset.executionState = "complete";
                        });
                        console.log(`[Auto-Clicker] 🏁 Sweep absolute. Processed: ${totalProcessed}`);
                    }
                } else {
                    structuralStagnantCycles = 0;
                }

                lastScrollHeight = currentScrollHeight;

            } catch (err) {
                console.log("[Auto-Clicker Error] Protected master execution loop from crash.");
            }
        }, tickInterval);
    }

    // EVENT-BUBBLE RESET CAPTURE: Completely resets counters when a user selects a clearing action node
    function resetVisitAllScript() {
        console.log("[Auto-Clicker] Clearing signal captured. Resetting script parameters...");
        
        if (engineTimer) {
            clearInterval(engineTimer);
            engineTimer = null;
        }

        const allStatusLinks = document.querySelectorAll('.gclh-custom-visit-all-link');
        allStatusLinks.forEach(link => {
            link.textContent = 'Visit All';
            link.style.color = '#3b82f6'; // Reset back to theme blue
            link.removeAttribute('data-execution-state');
        });
    }

    // UI RESTORATION LAYER: Places the inline link choice cleanly right before the targeted button
    function injectInlineVisitAllButton(masterDropBtn) {
        const parent = masterDropBtn.parentNode;
        if (!parent || parent.querySelector('.gclh-custom-visit-all-link')) return;

        console.log("[Auto-Clicker] Target matched. Mounting Visit All text option inline...");
        
        const visitAllBtn = document.createElement('button');
        visitAllBtn.className = "gclh-custom-visit-all-link inline-block m-0 p-0 border-0 text-base bg-transparent font-input underline cursor-pointer text-blue-500 hover:no-underline";
        visitAllBtn.type = 'button';
        visitAllBtn.textContent = 'Visit All';
        
        // Match margin alignments based on standard page text separation rules
        visitAllBtn.style.marginRight = "12px";
        visitAllBtn.style.display = "inline-block";

        visitAllBtn.addEventListener('click', (e) => {
            e.preventDefault();
            e.stopPropagation();
            if (visitAllBtn.dataset.executionState !== "running") {
                runInfiniteScrollAndClick();
            }
        });

        // Insert our inline choice cleanly right before the master macro button
        parent.insertBefore(visitAllBtn, masterDropBtn);
    }

    // WATCHDOG ENGINE: Monitors layout mutations cleanly without creating element conflicts
    function scanAndProcessState() {
        const allButtons = document.querySelectorAll('button');

        allButtons.forEach(button => {
            const btnText = button.textContent.trim().toLowerCase();
            const eventLabel = button.getAttribute('data-event-label') || '';

            // PROVISION RESET LOGIC: Listens to any dynamic clear triggers or "No Action" options seamlessly
            if (btnText === 'clear all' || btnText === 'clear-all' || btnText === 'no action' || eventLabel.includes('no action')) {
                if (button.dataset.resetEventHooked !== "true") {
                    button.dataset.resetEventHooked = "true";
                    button.addEventListener('click', () => {
                        setTimeout(resetVisitAllScript, 50);
                    });
                }
            }

            // PROVISION MOUNTING LOGIC: Finds the master tool rows by matching custom labels or explicit button content
            if (eventLabel === 'Cache Log - drop all' || btnText === 'drop all' || btnText === 'drop-all') {
                injectInlineVisitAllButton(button);
            }
        });
    }

    // Register active page layout structural tracking observer pipeline
    const uiObserver = new MutationObserver(() => scanAndProcessState());
    uiObserver.observe(document.documentElement, { childList: true, subtree: true });

    if (document.readyState === 'complete' || document.readyState === 'interactive') {
        scanAndProcessState();
    }
})();
